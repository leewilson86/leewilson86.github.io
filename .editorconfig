# EditorConfig keeps editor settings consistent across machines and IDEs.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Makefiles require literal TAB indentation.
[Makefile]
indent_style = tab

# Shell scripts use 2 spaces (matches src/scripts/smoke.sh).
[*.sh]
indent_style = space
indent_size = 2

# Markdown: keep trailing whitespace because two-space line breaks are
# meaningful in Markdown semantics.
[*.md]
trim_trailing_whitespace = false

